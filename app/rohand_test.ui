  <property name="windowTitle">
   <string>自动化测试平台</string>
  </property>
  <!-- 商业化配色样式表（高级灰+商务蓝） -->
  <property name="styleSheet">
   <string notr="true">
/* 主窗口背景：高级浅灰 */
QMainWindow {
    background-color: #f9fafb;
}

/* 分组框：商务风格+圆角 */
QGroupBox {
    font-size: 14px;
    font-weight: 600;
    color: #1f2937;
    border: 2px solid #e5e7eb;
    border-top-color: #f3f4f6;
    border-left-color: #f3f4f6;
    border-radius: 8px;
    margin-top: 12px;
    background-color: #ffffff;
    padding-top: 8px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 10px;
    color: #1e40af;
    font-size: 15px;
    font-weight: 700;
}

/* 主按钮：商务蓝渐变+3D效果 */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                              stop:0 #2563eb, stop:1 #1e40af);
    color: white;
    border: 3px solid;
    border-color: #3b82f6 #1e40af #1e40af #3b82f6;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 500;
}
QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                              stop:0 #3b82f6, stop:1 #2563eb);
    border-color: #60a5fa #2563eb #2563eb #60a5fa;
}
QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                              stop:0 #1e40af, stop:1 #1e3a8a);
    border-color: #1e40af #3b82f6 #3b82f6 #1e40af;
    padding-left: 8px;
    padding-top: 8px;
}

/* 日志功能小按钮：轻量化样式 */
QPushButton#log_copy_btn, QPushButton#log_clear_btn, QPushButton#log_save_btn {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                              stop:0 #f3f4f6, stop:1 #e5e7eb);
    color: #1f2937;
    border-color: #d1d5db #9ca3af #9ca3af #d1d5db;
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 12px;
}
QPushButton#log_copy_btn:hover, QPushButton#log_clear_btn:hover, QPushButton#log_save_btn:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                              stop:0 #e5e7eb, stop:1 #d1d5db);
}

/* 标签：商务灰文字 */
QLabel {
    font-size: 13px;
    color: #374151;
}

/* 下拉框：商务风格 */
QComboBox {
    border: 3px solid;
    border-color: #f3f4f6 #d1d5db #d1d5db #f3f4f6;
    border-radius: 6px;
    padding: 4px 8px;
    background-color: white;
    min-height: 25px;
}
QComboBox::drop-down {
    border: none;
}
QComboBox::down-arrow {
    width: 12px;
    height: 12px;
}
QComboBox QAbstractItemView {
    border: 3px solid #2563eb;
    border-color: #3b82f6 #1e40af #1e40af #3b82f6;
    border-radius: 6px;
    background-color: white;
    selection-background-color: #dbeafe;
    selection-color: #1e40af;
}

/* 复选框：商务风格 */
QCheckBox {
    font-size: 13px;
    color: #374151;
}
QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 3px solid;
    border-color: #f3f4f6 #d1d5db #d1d5db #f3f4f6;
    border-radius: 4px;
    background-color: white;
}
QCheckBox::indicator:checked {
    background-color: #2563eb;
}
QCheckBox::indicator:hover {
    border-color: #d1d5db #9ca3af #9ca3af #d1d5db;
}

/* 表格：商务风格 */
QTableWidget {
    border: 3px solid;
    border-color: #f3f4f6 #d1d5db #d1d5db #f3f4f6;
    border-radius: 6px;
    background-color: white;
    gridline-color: #e5e7eb;
}
QTableWidget::item {
    padding: 6px;
}
QTableWidget::item:selected {
    background-color: #dbeafe;
    color: #1e40af;
}
QHeaderView::section {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                              stop:0 #f3f4f6, stop:1 #e5e7eb);
    border: none;
    border-bottom: 2px solid #d1d5db;
    padding: 8px;
    font-weight: 600;
    color: #1e40af;
    border-radius: 4px;
}

/* 日志文本框：商务风格 */
QTextEdit#log_text_edit {
    border: 3px solid;
    border-color: #f3f4f6 #d1d5db #d1d5db #f3f4f6;
    border-radius: 6px;
    background-color: #ffffff;
    font-family: "Consolas", "Monaco", monospace;
    font-size: 12px;
    color: #1f2937;
}

/* 进度条：商务蓝 */
QProgressBar {
    border: 3px solid;
    border-color: #f3f4f6 #d1d5db #d1d5db #f3f4f6;
    border-radius: 6px;
    text-align: center;
    background-color: #f3f4f6;
}
QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
                              stop:0 #2563eb, stop:1 #1e40af);
    border-radius: 4px;
    border: 1px solid #1e40af;
}

/* 菜单栏：商务风格 */
QMenuBar {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                              stop:0 #f3f4f6, stop:1 #e5e7eb);
    border-bottom: 3px solid #d1d5db;
    font-size: 13px;
}
QMenuBar::item {
    padding: 6px 15px;
    margin: 2px;
    border-radius: 6px;
    border: 2px solid transparent;
}
QMenuBar::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                              stop:0 #2563eb, stop:1 #1e40af);
    color: white;
    border-color: #3b82f6 #1e40af #1e40af #3b82f6;
}

/* 菜单：商务风格 */
QMenu {
    background-color: white;
    border: 3px solid;
    border-color: #f3f4f6 #d1d5db #d1d5db #f3f4f6;
    border-radius: 6px;
    padding: 4px;
}
QMenu::item {
    padding: 6px 25px;
    border-radius: 6px;
    font-size: 13px;
    border: 2px solid transparent;
}
QMenu::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                              stop:0 #2563eb, stop:1 #1e40af);
    color: white;
    border-color: #3b82f6 #1e40af #1e40af #3b82f6;
}
QMenu::separator {
    height: 2px;
    background-color: #e5e7eb;
    margin: 4px 8px;
}
   </string>
  </property>
