   </rect>
  </property>
  <property name="windowTitle">
   <string>APP应用自动化测试</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
QMainWindow {
	background-color: #f0f2f5;
}
QGroupBox {
	font-weight: bold;
	border: 1px solid #dcdfe6;
	border-radius: 4px;
	margin-top: 10px;
	background-color: #ffffff;
}
QGroupBox::title {
	subcontrol-origin: margin;
	subcontrol-position: top left;
	padding: 0 5px;
	left: 10px;
	color: #606266;
}
QTableWidget {
	border: none;
	gridline-color: #ebeef5;
	selection-background-color: #409eff;
}
QHeaderView::section {
	background-color: #f5f7fa;
	border: none;
	border-right: 1px solid #ebeef5;
	border-bottom: 1px solid #ebeef5;
	height: 30px;
	color: #909399;
}
/* 通用按钮样式 (会被下方特定ID覆盖) */
QPushButton {
	background-color: #ffffff;
	border: 1px solid #dcdfe6;
	border-radius: 4px;
	padding: 5px 15px;
	color: #606266;
}
QPushButton:hover {
	color: #409eff;
	border-color: #c6e2ff;
	background-color: #ecf5ff;
}
QTextEdit {
	border: 1px solid #dcdfe6;
	border-radius: 4px;
	background-color: #fafafa;
	font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
}

/* ================= 底部面板新样式 (New Pro Style) ================= */

/* 底部容器背景 */
#bottom_panel {
	background-color: #ffffff;
	border-top: 1px solid #e4e7ed;
}

/* --- 控制按钮区域 --- */
/* 主开始按钮 - Hero Button */
#start_btn {
	background-color: #409eff;
	color: white;
	border: none;
	border-radius: 6px;
	font-size: 14px;
	font-weight: bold;
	padding: 8px 20px;
}
#start_btn:hover {
	background-color: #66b1ff;
}
#start_btn:pressed {
	background-color: #3a8ee6;
}

/* 停止按钮 - 危险色 */
#stop_btn {
	background-color: #fef0f0;
	color: #f56c6c;
	border: 1px solid #fbc4c4;
	border-radius: 6px;
}
#stop_btn:hover {
	background-color: #f56c6c;
	color: white;
}

/* 暂停按钮 */
#pause_btn {
	border-radius: 6px;
}

/* --- 进度条区域 --- */
QProgressBar {
	border: none;
	background-color: #ebeef5;
	border-radius: 4px;
	text-align: center;
}
QProgressBar::chunk {
	background-color: #409eff;
	border-radius: 4px;
}
/* 状态文字 */
#label_status {
	color: #909399;
	font-size: 12px;
}
#label_percent {
	color: #409eff;
	font-weight: bold;
	font-family: Arial;
}

/* --- 结果仪表盘区域 (KPI Cards) --- */
/* 数字大字体 */
.stat_number {
	font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
	font-size: 26px;
	font-weight: bold;
	background: transparent;
}
/* 标签小字体 */
.stat_label {
	font-size: 12px;
	color: #909399;
	font-weight: bold;
}
/* 颜色定义 */
#stat_num_total { color: #303133; }
#stat_num_pass { color: #67c23a; }
#stat_num_fail { color: #f56c6c; }

</string>
  </property>
