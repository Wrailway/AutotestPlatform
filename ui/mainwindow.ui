<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1200</width>
    <height>800</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>AutoTest Pro | 智能自动化测试平台</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* 全局基础 - 柔和的浅灰背景 */
    QMainWindow { background-color: #F8F9FA; }
    QWidget { font-family: &quot;Microsoft YaHei&quot;; }

    /* 主标题 - 深灰黑色 */
    QLabel#title_label {
     font-size: 48px;
     font-weight: 700;
     color: #1A1C23;
     margin-bottom: 60px;
     text-align: center;
    }

    /* 四个按钮统一样式 - 柔和浅蓝灰背景（核心修改） */
    QPushButton#btn_app, QPushButton#btn_robot, QPushButton#btn_ai, QPushButton#btn_server {
     background-color: #a3a7ad; /* 柔和浅蓝灰，替代纯白 */
     border: 2px solid #DEE8F5;
     border-radius: 12px;
     min-height: 220px;
     min-width: 320px;
     padding: 20px;
    }
    /* 悬浮效果 - 科技蓝主色 */
    QPushButton#btn_app:hover, QPushButton#btn_robot:hover, QPushButton#btn_ai:hover, QPushButton#btn_server:hover {
     background-color: #165DFF;
     color: #FFFFFF;
     border-color: #165DFF;
     border-width: 3px;
    }

    /* 图标 - 适配浅蓝灰背景的深灰 */
    QLabel#icon_app, QLabel#icon_robot, QLabel#icon_ai, QLabel#icon_server {
     font-size: 90px !important;
     color: #165DFF; /* 科技蓝，与背景呼应且醒目 */
     margin-bottom: 15px;
     text-align: center;
    }
    QPushButton:hover QLabel#icon_app, 
    QPushButton:hover QLabel#icon_robot, 
    QPushButton:hover QLabel#icon_ai, 
    QPushButton:hover QLabel#icon_server {
     color: #FFFFFF;
    }

    /* 标题 - 适配浅蓝灰背景的深灰 */
    QLabel#title_app, QLabel#title_robot, QLabel#title_ai, QLabel#title_server {
     font-size: 24px !important;
     font-weight: 600;
     color: #121212;
     margin-bottom: 15px;
     text-align: center;
    }
    QPushButton:hover QLabel#title_app, 
    QPushButton:hover QLabel#title_robot, 
    QPushButton:hover QLabel#title_ai, 
    QPushButton:hover QLabel#title_server {
     color: #FFFFFF;
    }

    /* 描述 - 适配浅蓝灰背景的中灰 */
    QLabel#desc_app, QLabel#desc_robot, QLabel#desc_ai, QLabel#desc_server {
     font-size: 16px !important;
     color: #303032;
     text-align: center;
    }
    QPushButton:hover QLabel#desc_app, 
    QPushButton:hover QLabel#desc_robot, 
    QPushButton:hover QLabel#desc_ai, 
    QPushButton:hover QLabel#desc_server {
     color: #F8F9FA;
    }
   </string>
  </property>

