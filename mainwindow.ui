  <!-- 全局样式：通过控件路径精准匹配，避免同名冲突 -->
  <property name="styleSheet">
   <string notr="true">
    /* 全局基础 */
    QMainWindow { background-color: #FFFFFF; }
    QWidget { font-family: &quot;Microsoft YaHei&quot;; }

    /* 主标题 */
    QLabel#title_label {
     font-size: 48px;
     font-weight: 700;
     color: #212529;
     margin-bottom: 60px;
     text-align: center;
    }

    /* 四个按钮统一样式（尺寸/背景） */
    QPushButton#btn_app, QPushButton#btn_robot, QPushButton#btn_ai, QPushButton#btn_server {
     background-color: #F8F9FA;
     border: 2px solid #DEE2E6;
     border-radius: 8px;
     min-height: 220px;
     min-width: 320px;
     padding: 20px;
    }
    QPushButton#btn_app:hover, QPushButton#btn_robot:hover, QPushButton#btn_ai:hover, QPushButton#btn_server:hover {
     background-color: #007BFF;
     color: #FFFFFF;
     border-color: #007BFF;
    }

    /* 每个入口的图标（唯一命名+精准匹配） */
    QLabel#icon_app, QLabel#icon_robot, QLabel#icon_ai, QLabel#icon_server {
     font-size: 90px !important;
     color: #007BFF;
     margin-bottom: 15px;
     text-align: center;
    }

    /* 每个入口的标题（唯一命名+精准匹配） */
    QLabel#title_app, QLabel#title_robot, QLabel#title_ai, QLabel#title_server {
     font-size: 24px !important;
     font-weight: 600;
     color: #212529;
     margin-bottom: 15px;
     text-align: center;
    }

    /* 每个入口的描述（唯一命名+精准匹配） */
    QLabel#desc_app, QLabel#desc_robot, QLabel#desc_ai, QLabel#desc_server {
     font-size: 16px !important;
     color: #6C757D;
     text-align: center;
    }
   </string>
  </property>

