  <property name="styleSheet">
   <string notr="true">
/* 主窗口基础样式 */
QMainWindow {background-color: #f9fafb;}

/* 分组框样式（保持原有） */
QGroupBox {
    font-size: 16px;
    font-weight: 600;
    color: #1f2937;
    border: 2px solid #e5e7eb;
    border-top-color: #f3f4f6;
    border-left-color: #f3f4f6;
    border-radius: 8px;
    margin-top: 12px;
    background-color: #ffffff;
    padding-top: 8px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 10px;
    color: #2563eb;
    font-size: 17px;
    font-weight: 700;
}

/* 按钮样式（保持原有） */
QPushButton {
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,stop:0 #4d9eff,stop:1 #3b82f6);
    color: white;
    border: 3px solid;
    border-color: #73b6ff #3b82f6 #3b82f6 #73b6ff;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 15px;
    font-weight: 500;
}
QPushButton:hover {
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,stop:0 #73b6ff,stop:1 #4d9eff);
    border-color: #99ccff #4d9eff #4d9eff #99ccff;
}
QPushButton:pressed {
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,stop:0 #2563eb,stop:1 #1e40af);
    border-color: #2563eb #4d9eff #4d9eff #2563eb;
    padding-left: 8px;
    padding-top: 8px;
}
QPushButton#start_test_btn, QPushButton#pause_test_btn, QPushButton#stop_test_btn {
    font-size: 20px;
    font-weight: 600;
}

/* 标签样式（保持原有） */
QLabel {
    font-size: 15px;
    color: #374151;
}
QLabel#total_case_label, QLabel#total_case_value {color: #4b5563; font-weight: 600;}
QLabel#success_case_label, QLabel#success_case_value {color: #10b981; font-weight: 600;}
QLabel#fail_case_label, QLabel#fail_case_value {color: #ef4444; font-weight: 600;}
QLabel#skip_case_label, QLabel#skip_case_value {color: #f59e0b; font-weight: 600;}

/* 下拉框样式（保持原有） */
QComboBox {
    border: 3px solid;
    border-color: #f3f4f6 #d1d5db #d1d5db #f3f4f6;
    border-radius: 6px;
    padding: 4px 8px;
    background-color: white;
    min-height: 28px;
    font-size: 15px;
}
QComboBox::drop-down {border: none;}
QComboBox::down-arrow {width: 14px; height: 14px;}
QComboBox QAbstractItemView {
    border: 3px solid #3b82f6;
    border-color: #73b6ff #3b82f6 #3b82f6 #73b6ff;
    border-radius: 6px;
    background-color: white;
    selection-background-color: #e6f2ff;
    selection-color: #2563eb;
    font-size: 15px;
}

/* 复选框样式（保持原有） */
QCheckBox {
    font-size: 15px;
    color: #374151;
}
QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border: 3px solid;
    border-color: #f3f4f6 #d1d5db #d1d5db #f3f4f6;
    border-radius: 4px;
    background-color: white;
}
QCheckBox::indicator:checked {background-color: #3b82f6;}
QCheckBox::indicator:hover {
    border-color: #d1d5db #9ca3af #9ca3af #d1d5db;
}

/* 表格样式（保持原有） */
QTableWidget {
    border: 3px solid;
    border-color: #f3f4f6 #d1d5db #d1d5db #f3f4f6;
    border-radius: 6px;
    background-color: white;
    gridline-color: #e5e7eb;
    font-size: 15px;
    stretch: 1;
}
QTableWidget::item {padding: 20px;}
QTableWidget::item:selected {
    background-color: #e6f2ff;
    color: #2563eb;
}
QHeaderView::section {
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,stop:0 #f3f4f6,stop:1 #e5e7eb);
    border: none;
    border-bottom: 2px solid #d1d5db;
    padding: 8px;
    font-weight: 600;
    color: #2563eb;
    border-radius: 4px;
    font-size: 15px;
}

/* 日志框样式（保持原有） */
QTextEdit#log_text_edit {
    border: 3px solid;
    border-color: #f3f4f6 #d1d5db #d1d5db #f3f4f6;
    border-radius: 6px;
    background-color: #ffffff;
    font-family: "Consolas", "Monaco", monospace;
    font-size: 14px;
    color: #1f2937;
}

/* 进度条样式（保持原有） */
QProgressBar {
    border: 3px solid;
    border-color: #f3f4f6 #d1d5db #d1d5db #f3f4f6;
    border-radius: 6px;
    text-align: center;
    background-color: #f3f4f6;
    font-size: 15px;
    color: #ffffff;
    font-weight: 600;
}
QProgressBar::chunk {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #4d9eff,stop:1 #3b82f6);
    border-radius: 4px;
    border: 1px solid #3b82f6;
}

/* ========== 重点优化：菜单栏样式 ========== */
/* 主菜单栏样式（与整体浅灰底色统一） */
QMenuBar {
    background-color: #f9fafb; /* 匹配主窗口底色 */
    border-bottom: 2px solid #e5e7eb; /* 轻量化分割线 */
    font-size: 15px;
    font-weight: 500;
    color: #1f2937; /* 文字颜色匹配分组框 */
}

/* 主菜单项默认状态 */
QMenuBar::item {
    padding: 8px 18px;
    margin: 2px;
    border-radius: 6px;
    color: #1f2937;
    background-color: transparent;
    border: 2px solid transparent;
}

/* 主菜单项悬停/选中状态（匹配按钮渐变风格） */
QMenuBar::item:selected {
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,stop:0 #4d9eff,stop:1 #3b82f6);
    color: white; /* 白色文字提高对比度 */
    border-color: #73b6ff #3b82f6 #3b82f6 #73b6ff; /* 匹配按钮边框 */
}

/* 子菜单容器样式（统一圆角+边框） */
QMenu {
    background-color: #ffffff; /* 白色背景匹配分组框 */
    border: 2px solid #e5e7eb; /* 轻量化边框 */
    border-radius: 8px; /* 匹配分组框圆角 */
    padding: 8px 0; /* 优化内边距 */
    font-size: 15px;
    color: #1f2937;
}

/* 子菜单项样式 */
QMenu::item {
    padding: 8px 28px;
    margin: 0 4px; /* 优化外边距 */
    border-radius: 6px;
    color: #1f2937;
    border: 2px solid transparent;
}

/* 子菜单项悬停状态（匹配按钮风格） */
QMenu::item:selected {
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,stop:0 #4d9eff,stop:1 #3b82f6);
    color: white;
    border-color: #73b6ff #3b82f6 #3b82f6 #73b6ff;
}

/* 子菜单分隔线（轻量化） */
QMenu::separator {
    height: 2px;
    background-color: #e5e7eb; /* 匹配边框颜色 */
    margin: 6px 10px;
}
   </string>
